{
  "expo": {
    "name": "Outfit Styling",
    "slug": "fashion-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/Icon1.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/Main.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shitanshu.outfitstyling"
    },
    "android": {
      "package": "com.shitanshu.outfitstyling",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/Icon1.png",
        "backgroundColor": "#FAF6F0"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Outfit Styling to access your location for weather-based styling tips."
        }
      ],
      "expo-document-picker",
      "expo-image-picker",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "3c236786-db8d-47c7-a84c-9b223afd7e2d"
      }
    }
  }
}
